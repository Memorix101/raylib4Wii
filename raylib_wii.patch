+/* raylib: glTF buffer data and GLB header fields are stored little-endian; convert
+   to host order so parsing works on big-endian targets (PowerPC / Nintendo Wii, GameCube) */
+#if defined(GEKKO) || defined(__BIG_ENDIAN__) || (defined(__BYTE_ORDER__) && (__BYTE_ORDER__ == __ORDER_BIG_ENDIAN__))
+	#define CGLTF_BIG_ENDIAN 1
+#else
+	#define CGLTF_BIG_ENDIAN 0
+#endif
+
+static uint32_t cgltf_read_u32_le(const void* ptr)
+{
+	uint32_t v;
+	memcpy(&v, ptr, 4);
+#if CGLTF_BIG_ENDIAN
+	v = ((v & 0xFF000000u) >> 24) | ((v & 0x00FF0000u) >> 8) |
+	    ((v & 0x0000FF00u) << 8)  | ((v & 0x000000FFu) << 24);
+#endif
+	return v;
+}
+
+static uint16_t cgltf_read_u16_le(const void* ptr)
+{
+	uint16_t v;
+	memcpy(&v, ptr, 2);
+#if CGLTF_BIG_ENDIAN
+	v = (uint16_t)(((v & 0xFF00u) >> 8) | ((v & 0x00FFu) << 8));
+#endif
+	return v;
+}
+
+static float cgltf_read_f32_le(const void* ptr)
+{
+	uint32_t u = cgltf_read_u32_le(ptr);
+	float f;
+	memcpy(&f, &u, 4);
+	return f;
+}
