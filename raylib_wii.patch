diff --git a/src/rlgl.h b/src/rlgl.h
index d219ca5e..8f6590ed 100644
--- a/src/rlgl.h
+++ b/src/rlgl.h
@@ -3462,6 +3462,19 @@ unsigned int rlLoadTexture(const void *data, int width, int height, int format,
         glTexParameteri(GL_TEXTURE_2D, GL_TEXTURE_WRAP_S, GL_CLAMP_TO_EDGE);       // Set texture to clamp on x-axis
         glTexParameteri(GL_TEXTURE_2D, GL_TEXTURE_WRAP_T, GL_CLAMP_TO_EDGE);       // Set texture to clamp on y-axis
     }
+#elif defined(PLATFORM_WII) || defined(PLATFORM_GAMECUBE)
+    // GX REPEAT/MIRROR wrap modes only work with power-of-two textures (they address texels with
+    // a POT bitmask); a NPOT texture with REPEAT renders sheared. Use CLAMP_TO_EDGE for NPOT.
+    if (((width & (width - 1)) == 0) && ((height & (height - 1)) == 0))
+    {
+        glTexParameteri(GL_TEXTURE_2D, GL_TEXTURE_WRAP_S, GL_REPEAT);
+        glTexParameteri(GL_TEXTURE_2D, GL_TEXTURE_WRAP_T, GL_REPEAT);
+    }
+    else
+    {
+        glTexParameteri(GL_TEXTURE_2D, GL_TEXTURE_WRAP_S, GL_CLAMP_TO_EDGE);   // NPOT: clamp to avoid GX REPEAT shearing
+        glTexParameteri(GL_TEXTURE_2D, GL_TEXTURE_WRAP_T, GL_CLAMP_TO_EDGE);
+    }
 #else
     glTexParameteri(GL_TEXTURE_2D, GL_TEXTURE_WRAP_S, GL_REPEAT);       // Set texture to repeat on x-axis
     glTexParameteri(GL_TEXTURE_2D, GL_TEXTURE_WRAP_T, GL_REPEAT);       // Set texture to repeat on y-axis
diff --git a/src/rmodels.c b/src/rmodels.c
index 9f6a7135..eba4c931 100644
--- a/src/rmodels.c
+++ b/src/rmodels.c
@@ -5459,6 +5459,25 @@ static BoneInfo *LoadBoneInfoGLTF(cgltf_skin skin, int *boneCount)
     return bones;
 }
 
+// Byte-swap a value in place to convert little-endian glTF buffer data to host order.
+// NOTE: glTF buffer data is always little-endian; on big-endian targets (PowerPC /
+// Nintendo Wii, GameCube) it must be swapped. This is a no-op on little-endian hosts.
+static inline void rlGltfSwap(void *value, int size)
+{
+#if defined(GEKKO) || defined(__BIG_ENDIAN__) || (defined(__BYTE_ORDER__) && (__BYTE_ORDER__ == __ORDER_BIG_ENDIAN__))
+    unsigned char *b = (unsigned char *)value;
+    for (int i = 0; i < size/2; i++)
+    {
+        unsigned char t = b[i];
+        b[i] = b[size - 1 - i];
+        b[size - 1 - i] = t;
+    }
+#else
+    (void)value;
+    (void)size;
+#endif
+}
+
 // Load glTF file into model struct, .gltf and .glb supported
 static Model LoadGLTF(const char *fileName)
 {
@@ -5503,7 +5522,9 @@ static Model LoadGLTF(const char *fileName)
         {\
             for (int l = 0; l < numComp; l++) \
             {\
-                dstPtr[numComp*k + l] = (dstType)buffer[n + l];\
+                srcType v = buffer[n + l]; \
+                rlGltfSwap(&v, sizeof(srcType)); \
+                dstPtr[numComp*k + l] = (dstType)v;\
             }\
             n += (int)(accesor->stride/sizeof(srcType));\
         }\
